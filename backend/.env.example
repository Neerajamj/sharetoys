# Get this from MongoDB Atlas -> Connect -> Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sharetoys

# Any long random string
JWT_SECRET=change_this_to_a_long_random_secret

PORT=5000

# The deployed frontend URL (for CORS). Use http://localhost:5173 for local dev.
CLIENT_URL=http://localhost:5173
